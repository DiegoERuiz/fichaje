# 🌐 Fichaje - Variables de entorno PRODUCCIÓN
# IMPORTANTE: No subir este archivo con contraseñas reales a GitHub
# Usar git update-index --assume-unchanged .env para proteger cambios locales

# === PUERTOS ===
APP_PORT=80
APP_SSL_PORT=443
DB_PORT=3306

# === SSL/TLS (Let's Encrypt + Caddy) ===
ENABLE_SSL=true
DOMAIN=fichajes.biedma.com
LETSENCRYPT_EMAIL=admin@biedma.com

# === BASE DE DATOS MYSQL ===
# IMPORTANTE: Cambiar en producción con contraseñas seguras (32+ caracteres)
MYSQL_ROOT_PASSWORD=root_password_seguro_32_caracteres_minimo!!!
MYSQL_DATABASE=db_fichajespi_prod
MYSQL_USER=fichajes_prod
MYSQL_PASSWORD=mysql_password_seguro_32_caracteres_minimo!!!
TZ=Europe/Madrid

# === URLS Y DOMINIOS ===
IP=fichajes.biedma.com
CLIENT_URL=https://fichajes.biedma.com

# === MAIL SMTP ===
SPRING_MAIL_HOST=smtp.example.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=noreply@biedma.com
SPRING_MAIL_PASSWORD=smtp_password
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

# === JWT (mínimo 192 caracteres aleatorios) ===
JWT_SECRET=generar_con_openssl_rand_hex_192_caracteres_de_entropia_alta!!!
JWT_REFRESH_EXPIRATION=604800000
SSL_KEYSTORE_PASSWORD=keystore_password_seguro_32_caracteres!!!

# === IMÁGENES DOCKER ===
FRONTEND_IMAGE=ghcr.io/jamataran/fichaje-frontend:latest
BACKEND_IMAGE=ghcr.io/jamataran/fichaje-backend:latest

