# Variables de entorno para DESARROLLO LOCAL

# Puertos (por defecto: BD=3307, phpMyAdmin=8081, MailHog SMTP=1025, MailHog UI=8025)
DB_PORT=3307
PHPMYADMIN_PORT=8081
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# Base de datos
MYSQL_ROOT_PASSWORD=dev_root_pass
MYSQL_DATABASE=db_fichajespi_dev
MYSQL_USER=fichajes_dev
MYSQL_PASSWORD=fichajes_dev
TZ=Europe/Madrid

# Backend/Frontend
IP=localhost
CLIENT_URL=http://localhost

# MailHog (captura emails)
SPRING_MAIL_HOST=mailhog
SPRING_MAIL_PORT=1025
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=false
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=false

JWT_SECRET=dev-secret-key-change

