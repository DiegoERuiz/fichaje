# 🌐 FICHAJE - EJEMPLO DE CONFIGURACIÓN
# ⚠️ NUNCA SUBIR .env REAL AL REPOSITORIO
# Copia este archivo a .env y rellena con valores reales

# ═══════════════════════════════════════════════════════════
# PUERTOS
# ═══════════════════════════════════════════════════════════
APP_PORT=8080
APP_SSL_PORT=8443
DB_PORT=3306
PHPMYADMIN_PORT=8081
REDIS_PORT=6379
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# ═══════════════════════════════════════════════════════════
# SSL CON LET'S ENCRYPT
# ═══════════════════════════════════════════════════════════
ENABLE_SSL=true
DOMAIN=fichajes.biedma.com
LETSENCRYPT_EMAIL=admin@fichajes.biedma.com

# ═══════════════════════════════════════════════════════════
# BASE DE DATOS (GENERAR NUEVAS CONTRASEÑAS)
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(12))"
# ═══════════════════════════════════════════════════════════
MYSQL_ROOT_PASSWORD=<GENERAR_CON_SECRETS>
MYSQL_DATABASE=db_fichajespi_prod
MYSQL_USER=fichajes_prod
MYSQL_PASSWORD=<GENERAR_CON_SECRETS>
MYSQL_INITDB_SKIP_TZINFO=yes
TZ=Europe/Madrid

# ═══════════════════════════════════════════════════════════
# JWT TOKENS (GENERAR CON: python -c "import secrets; print(secrets.token_urlsafe(144))")
# ═══════════════════════════════════════════════════════════
JWT_SECRET=<GENERAR_CON_SECRETS_-_MINIMO_192_CARACTERES>
JWT_EXPIRATION=36000000
JWT_REFRESH_EXPIRATION=604800000

# ═══════════════════════════════════════════════════════════
# SSL KEYSTORE (GENERAR CON: python -c "import secrets; print(secrets.token_urlsafe(12))")
# ═══════════════════════════════════════════════════════════
SSL_KEYSTORE_PASSWORD=<GENERAR_CON_SECRETS>
SSL_KEYSTORE_ALIAS=fichaje
KEYSTORE_PATH=/opt/fichaje/fichajes-keystore.p12

# ═══════════════════════════════════════════════════════════
# URLs Y DOMINIO
# ═══════════════════════════════════════════════════════════
APP_DOMAIN=fichajes.biedma.com
APP_URL=https://fichajes.biedma.com
CLIENT_URL=https://fichajes.biedma.com

# ═══════════════════════════════════════════════════════════
# MAIL SMTP (OPCIONAL - Configurar después si se necesita)
# ═══════════════════════════════════════════════════════════
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=noreply@fichajes.biedma.com
SPRING_MAIL_PASSWORD=<TU_CONTRASEÑA_APP>
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

# ═══════════════════════════════════════════════════════════
# SERVICIOS OPCIONALES
# ═══════════════════════════════════════════════════════════
REDIS_HOST=redis
REDIS_PORT=6379

PROMETHEUS_PORT=9090
GRAFANA_PASSWORD=<GENERAR_CON_SECRETS>
GRAFANA_ADMIN_USER=admin

# ═══════════════════════════════════════════════════════════
# IMÁGENES DOCKER
# ═══════════════════════════════════════════════════════════
FRONTEND_IMAGE=ghcr.io/jamataran/fichaje-frontend:latest
BACKEND_IMAGE=ghcr.io/jamataran/fichaje-backend:latest

# ═══════════════════════════════════════════════════════════
# SPRING BOOT PROFILES
# ═══════════════════════════════════════════════════════════
SPRING_PROFILES_ACTIVE=prod
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# ═══════════════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════════════
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK=WARN
LOGGING_LEVEL_COM_BIEDMA=DEBUG
